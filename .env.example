# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JSON_BODY_LIMIT=15mb

# DB_DRIVER can be: json, mongodb, supabase, mysql
DB_DRIVER=json

# JSON local adapter
JSON_DB_FILE=.data/k92-db.json
SEED_FILE=data/seed.json

# MongoDB adapter
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=92kamera
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_KV_COLLECTION=kv_store
MONGODB_GALLERY_COLLECTION=gallery_photos

# Supabase adapter
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MySQL adapter
MYSQL_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Admin auth
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret
ADMIN_SESSION_TTL_SECONDS=43200
# Default password is admin92. Override by setting a SHA-256 hash.
# ADMIN_PASSWORD_HASH=db08beaae1b06ae2e84f101f8e37a8c03e16eb8e514ec8c2274b5d89aa2f9d22

# Cloudinary (image upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
