{
  "name": "92kamera-be",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --signal SIGINT --exec tsx src/server.ts",
    "seed": "tsx src/scripts/seed.ts",
    "seed:dist": "node dist/scripts/seed.js",
    "migrate:purge-base64": "tsx src/scripts/migrate-purge-base64-photos.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongodb": "^6.8.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "nodemon": "^3.1.14",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
